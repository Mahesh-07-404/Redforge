# Base Environment Configurations
REDFORGE_ENV=development
REDFORGE_HOST=127.0.0.1
REDFORGE_PORT=8000
REDFORGE_LOG_LEVEL=DEBUG
REDFORGE_RATE_LIMIT=100

# Security (JWT secret should be a 32-character secure string in production)
REDFORGE_JWT_SECRET=your_jwt_secret_key_here

# API Keys (e.g. Google Gemini, OpenAI, Anthropic)
# Google API Key / Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here
